/* pages/calendar/calendar.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 120rpx;
}

/* 月份头部 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.month-btn {
  padding: 20rpx;
}

.arrow {
  font-size: 48rpx;
  color: #4CAF50;
  font-weight: bold;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 星期标题 */
.weekday-row,
.days-row {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
}

.weekday {
  width: 80rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

/* 日历网格容器 */
.days-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 10rpx;
  padding: 0 10rpx;
}

/* 日期格子 */
.day-cell {
  width: 80rpx;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f0f0f0;
  margin-bottom: 10rpx;
}

.day-number {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.day-emotion {
  font-size: 32rpx;
  margin-top: 4rpx;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ddd;
  margin-top: 4rpx;
}

.day-cell.has-record {
  background: #f8f8f8;
}

.day-cell.today {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.day-cell.today .day-number {
  color: #4CAF50;
}

/* 本月统计 */
.month-stats {
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
}

/* 图例说明 */
.calendar-tips {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 30rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.tips-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.legend-icon {
  font-size: 32rpx;
}

/* 日期详情弹窗 */
.day-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.day-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.day-modal .modal-content {
  width: 80%;
  max-height: 60%;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 10rpx;
}

/* 记录行 */
.day-records {
  max-height: 600rpx;
}

.record-row {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-row:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.record-emotion {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.record-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.empty-day {
  text-align: center;
  padding: 60rpx;
  color: #999;
}