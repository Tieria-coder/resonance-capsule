/* pages/calendar/calendar.wxss - 黑白质感风格（小程序兼容） */

.container {
  min-height: 100vh;
  background: #fafafc;
  padding: 30rpx;
  padding-bottom: 120rpx;
}

/* ═══ 月份头部 ═══ */
.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.month-btn {
  padding: 20rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  border: 1.5rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.month-btn:active {
  background: rgba(255,255,255,0.7);
}

.arrow {
  font-size: 48rpx;
  color: #1a1a1a;
  font-weight: 300;
}

.month-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

/* ═══ 星期标题 ═══ */
.weekday-row,
.days-row {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0;
}

.weekday {
  width: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

/* ═══ 日历网格容器 ═══ */
.days-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 10rpx;
  padding: 0 10rpx;
}

/* ═══ 日期格子 ═══ */
.day-cell {
  width: 80rpx;
  height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.35);
  margin-bottom: 10rpx;
  border: 1.5rpx solid rgba(255,255,255,0.5);
  transition: all 0.2s;
}

.day-cell:active {
  transform: scale(0.95);
  background: rgba(255,255,255,0.5);
}

.day-number {
  font-size: 28rpx;
  color: #333;
  font-weight: 400;
}

.day-emotion {
  font-size: 28rpx;
  margin-top: 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.day-icon {
  line-height: 1;
}

.day-count {
  font-size: 16rpx;
  color: #999;
  background: rgba(0,0,0,0.04);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.1);
  margin-top: 4rpx;
}

.day-cell.has-record {
  background: rgba(255,255,255,0.55);
  border-color: rgba(255,255,255,0.7);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.day-cell.today {
  background: rgba(26,26,26,0.06);
  border: 1.5rpx solid rgba(26,26,26,0.15);
}

.day-cell.today .day-number {
  color: #1a1a1a;
  font-weight: 500;
}

/* ═══ 本月统计 ═══ */
.month-stats {
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
}



/* ═══ 连续记录 + 温暖语 ═══ */
.monthly-highlight {
  background: rgba(255,255,255,0.75);
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-top: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07), 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.streak-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.streak-icon {
  font-size: 36rpx;
  line-height: 1;
}

.streak-text {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.monthly-message {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  padding: 16rpx 20rpx;
  background: rgba(0,0,0,0.02);
  border-radius: 12rpx;
  border-left: 4rpx solid rgba(26,26,26,0.15);
}

/* ═══ 情绪分布卡片 ═══ */
.emotion-stats-card {
  background: rgba(255,255,255,0.75);
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-top: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07), 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.stats-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.stats-total {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.stats-bars {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stats-icon {
  font-size: 30rpx;
  line-height: 1;
  width: 40rpx;
  text-align: center;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  width: 60rpx;
}

.stats-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(0,0,0,0.04);
  border-radius: 8rpx;
  overflow: hidden;
}

.stats-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1a1a1a, #555);
  border-radius: 8rpx;
  transition: width 0.4s ease;
  min-width: 4rpx;
}

.stats-count {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
}

/* ═══ 日期详情弹窗 ═══ */
.day-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.day-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.day-modal .modal-content {
  width: 85%;
  max-height: 65%;
  background: rgba(245,245,245,0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  overflow-y: auto;
  border: 1.5rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
  transform: translateY(40rpx);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.day-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.modal-close:active {
  color: #666;
}

/* ═══ 记录行 ═══ */
.day-records {
  max-height: 600rpx;
}

.record-row {
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.record-row:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.record-emotion {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 400;
  margin-bottom: 8rpx;
}

.record-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.6;
}

/* AI 回应 */
.record-ai {
  display: flex;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(245,243,255,0.5);
  border-radius: 12rpx;
  border: 1rpx solid rgba(221,214,254,0.5);
}

.ai-label {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}

.ai-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.empty-day {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 26rpx;
}

/* icons */
.streak-icon { width: 48rpx; height: 48rpx; }
.streak-icon image { width: 100%; height: 100%; }
.ai-label image { width: 28rpx; height: 28rpx; vertical-align: middle; margin-right: 4rpx; }
.modal-close image { width: 36rpx; height: 36rpx; }
