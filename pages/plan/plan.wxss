/* pages/plan/plan.wxss - 情绪计划页面样式 */

/* ═══ 图标图片覆盖（emoji 替换） ═══ */
.page-desc image, .mp-icon, .empty-icon image, .modal-close image { width: 100%; height: 100%; }
.mp-icon { width: 36rpx; height: 36rpx; }
.empty-icon image { width: 120rpx; height: 120rpx; }
.modal-close image { width: 36rpx; height: 36rpx; }
.icon-xs-inline { width: 28rpx; height: 28rpx; display: inline-block; vertical-align: middle; }
.icon-xs-inline { width: 28rpx; height: 28rpx; display: inline-block; vertical-align: middle; }

page {
  background: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding: 0 0 140rpx;
}

/* 页面标题 */
.page-header {
  padding: 60rpx 40rpx 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 分区标题 */
.section {
  padding: 20rpx 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #333;
}

/* 我的计划卡片 */
.my-plan-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.my-plan-card {
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1.5rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.mp-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.mp-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.mp-theme {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.mp-leave-btn {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 20rpx;
  border: 1.5rpx solid rgba(0,0,0,0.1);
  border-radius: 20rpx;
}

/* 进度条 */
.mp-progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.mp-progress-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(0,0,0,0.06);
  border-radius: 6rpx;
  overflow: hidden;
}

.mp-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #333, #666);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.mp-progress-text {
  font-size: 24rpx;
  color: #888;
  white-space: nowrap;
}

/* 信息行 */
.mp-info-row {
  display: flex;
  gap: 28rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.mp-info-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #777;
}

.mp-icon {
  font-size: 24rpx;
}

/* 去记录按钮 */
.mp-record-btn {
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  background: #1a1a1a;
  padding: 20rpx 0;
  border-radius: 16rpx;
  letter-spacing: 4rpx;
}

.mp-record-btn:active {
  opacity: 0.7;
}

/* 可加入的计划卡片 */
.plan-template-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.plan-template-card {
  position: relative;
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  border: 1.5rpx solid rgba(0,0,0,0.06);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.plan-template-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.pt-badge {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  background: #1a1a1a;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.pt-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 10rpx;
  padding-right: 80rpx;
}

.pt-theme {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(0,0,0,0.04);
  display: inline-block;
  border-radius: 8rpx;
}

.pt-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.pt-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.pt-join-hint {
  font-size: 24rpx;
  color: #888;
  text-align: right;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 100%;
  background: rgba(245,245,245,0.95);
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 36rpx 60rpx;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  max-height: 75vh;
  overflow-y: auto;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.reminder-modal {
  max-height: 70vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

.reminder-plan-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.reminder-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.reminder-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.reminder-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 16rpx;
  border: 1.5rpx solid transparent;
  transition: all 0.2s;
}

.reminder-option.selected {
  border-color: #1a1a1a;
  background: rgba(0,0,0,0.03);
}

.reminder-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  transition: all 0.2s;
}

.reminder-option.selected .reminder-check {
  background: #1a1a1a;
  border-color: #1a1a1a;
}

.reminder-label {
  font-size: 28rpx;
  color: #333;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  background: rgba(255,255,255,0.6);
  border-radius: 16rpx;
}

.btn-save {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #fff;
  background: #1a1a1a;
  border-radius: 16rpx;
  font-weight: 500;
}

.btn-save:active {
  opacity: 0.7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 底部安全区 */
.nav-placeholder {
  height: 120rpx;
}