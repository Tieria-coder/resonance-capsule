/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #fff;
  margin-bottom: 20rpx;
}

.user-nickname {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 40rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 区块 */
.section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 徽章网格 */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  width: 140rpx;
  height: 140rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0.4;
}

.badge-item.unlocked {
  opacity: 1;
  background: #FFF8E1;
}

.badge-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.badge-label {
  font-size: 22rpx;
  color: #666;
}

/* 菜单 */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: #F44336;
}

.menu-arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* ===== 自定义情绪图标弹窗 ===== */
.emoji-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.emoji-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.emoji-modal-content {
  width: 680rpx;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  transform: scale(0.9);
  transition: transform 0.3s ease;
  overflow-y: auto;
}

.emoji-modal.show .emoji-modal-content {
  transform: scale(1);
}

.emoji-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
}

.emoji-modal-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

/* 情绪自定义列表 */
.emotion-custom-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.emotion-custom-item {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.emotion-preview {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
  cursor: pointer;
}

.emotion-preview:active {
  transform: scale(0.95);
}

.emotion-preview-emoji {
  font-size: 56rpx;
}

.emotion-preview-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
}

.emotion-custom-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.emotion-custom-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.emotion-reset-btn {
  font-size: 22rpx;
  color: #F44336;
  padding: 4rpx 16rpx;
  border: 1rpx solid #F44336;
  border-radius: 20rpx;
}

.emotion-reset-btn:active {
  background: #F44336;
  color: #fff;
}

/* 编辑面板 */
.emotion-edit-panel {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #ddd;
  animation: slideDown 0.2s ease;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.edit-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.edit-emoji-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
}

.edit-emoji-input:focus {
  border-color: #4CAF50;
}

.edit-save-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
}

.edit-save-btn:active {
  opacity: 0.85;
}

.edit-divider-text {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin: 16rpx 0;
}

.edit-upload-btn {
  text-align: center;
  padding: 20rpx;
  background: #f0f0ff;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

.edit-upload-btn:active {
  background: #e0e0ff;
}
