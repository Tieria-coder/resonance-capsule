/* pages/profile/profile.wxss - 黑白质感风格（小程序兼容） */

/* ═══ 页面入场动画 ═══ */
@keyframes pageEntrance {
  0% { opacity: 0; transform: translateY(24rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes cardEntrance {
  0% { opacity: 0; transform: translateY(16rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.container {
  animation: pageEntrance 0.35s ease-out both;
}

.user-card { animation: cardEntrance 0.4s ease-out 0.05s both; }
.stats-card { animation: cardEntrance 0.4s ease-out 0.12s both; }
.menu-card { animation: cardEntrance 0.4s ease-out 0.19s both; }
.about-card { animation: cardEntrance 0.4s ease-out 0.26s both; }

/* ═══ 用户卡片 ═══ */
.user-card {
  background: rgba(26,26,26,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 60rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  clip-path: ellipse(100% 100% at 50% 0%);
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.9);
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.user-nickname {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
}

/* ═══ 统计卡片 ═══ */
.stats-card {
  background: rgba(255,255,255,0.75);
  margin: -40rpx 30rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 40rpx 20rpx;
  border: 1.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.07), 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(0,0,0,0.06);
}

/* ═══ 区块 ═══ */
.section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
}

/* ═══ 徽章网格 ═══ */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.badge-item {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0.4;
  border: 1.5rpx solid rgba(0,0,0,0.04);
  transition: all 0.3s ease;
}

.badge-item.unlocked {
  opacity: 1;
  background: rgba(255,255,255,0.75);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.badge-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.badge-label {
  font-size: 22rpx;
  color: #666;
}

/* ═══ 菜单 ═══ */
.menu-section {
  background: rgba(255,255,255,0.75);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07), 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
  font-size: 28rpx;
  color: #333;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(0,0,0,0.02);
}

.menu-item.danger {
  color: #f44336;
}

.menu-arrow {
  color: #ccc;
  font-size: 32rpx;
}

/* ═══ 弹窗（通用）═══ */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 85%;
  max-height: 80%;
  background: rgba(245,245,245,0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  overflow-y: auto;
  border: 1.5rpx solid rgba(255,255,255,0.5);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
  transform: translateY(40rpx);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 10rpx;
  line-height: 1;
}

.modal-close:active {
  color: #666;
}

.modal-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

/* ═══ 自定义情绪图标 - 列表 ═══ */
.emoji-list {
  max-height: 60vh;
}

.emotion-category {
  margin-bottom: 30rpx;
}

.category-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1.5rpx solid rgba(0,0,0,0.06);
}

.sub-emotion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.emotion-custom-item {
  background: rgba(255,255,255,0.75);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1.5rpx solid rgba(0,0,0,0.04);
}

.emotion-preview {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.emotion-preview:active {
  transform: scale(0.95);
}

.emotion-preview-emoji {
  font-size: 56rpx;
}

.emotion-preview-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
}

.emotion-custom-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.emotion-custom-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.emotion-reset-btn {
  font-size: 22rpx;
  color: #f44336;
  padding: 4rpx 16rpx;
  border: 1.5rpx solid #f44336;
  border-radius: 20rpx;
}

.emotion-reset-btn:active {
  background: #f44336;
  color: #fff;
}

/* 编辑面板 */
.emotion-edit-panel {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1.5rpx dashed rgba(0,0,0,0.1);
  animation: slideDown 0.2s ease;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.edit-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.edit-emoji-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255,255,255,0.9);
  border: 1.5rpx solid rgba(0,0,0,0.1);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #1a1a1a;
}

.edit-emoji-input:focus {
  border-color: #1a1a1a;
}

.edit-save-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: rgba(26,26,26,0.85);
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  white-space: nowrap;
  border: 1.5rpx solid rgba(255,255,255,0.9);
}

.edit-save-btn:active {
  background: rgba(26,26,26,0.95);
}

.edit-divider-text {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin: 16rpx 0;
}

.edit-upload-btn {
  text-align: center;
  padding: 20rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
  border: 1.5rpx solid rgba(0,0,0,0.06);
}

.edit-upload-btn:active {
  background: rgba(255,255,255,0.7);
}

/* ═══ 魔法衣橱 - 主题列表 ═══ */
.theme-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.theme-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.75);
  border-radius: 16rpx;
  border: 1.5rpx solid rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.theme-item:active {
  background: rgba(255,255,255,0.9);
}

.theme-item.active {
  border-color: #1a1a1a;
  background: rgba(255,255,255,0.9);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.theme-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.theme-preview-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}

.theme-info {
  flex: 1;
}

.theme-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.theme-desc {
  font-size: 22rpx;
  color: #999;
}

.theme-check {
  font-size: 36rpx;
  color: #1a1a1a;
  font-weight: 700;
}

.nav-placeholder {
  height: 120rpx;
}

/* icons */
.icon-sm-inline { width: 28rpx; height: 28rpx; display: inline-block; vertical-align: middle; margin-right: 8rpx; }
.icon-sm { width: 36rpx; height: 36rpx; }
.icon-sm image { width: 100%; height: 100%; }
.modal-close image { width: 36rpx; height: 36rpx; }

.icon-xs { width: 28rpx; height: 28rpx; }
.theme-check image { width: 28rpx; height: 28rpx; }
