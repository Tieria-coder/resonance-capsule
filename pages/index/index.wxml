<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="title">情绪胶囊</view>
  </view>

  <!-- AI 回应气泡 -->
  <view class="ai-bubble {{showAiResponse ? 'show' : ''}}" wx:if="{{showAiResponse && aiResponse}}" bindtap="closeAiResponse">
    <view class="ai-bubble-content">
      <view class="ai-bubble-icon">🤖</view>
      <view class="ai-bubble-text">{{aiResponse}}</view>
    </view>
    <view class="ai-bubble-hint">点击关闭</view>
  </view>

  <!-- 情绪记录按钮 -->
  <view class="record-section">
    <view class="record-btn-wrap">
      <view 
        class="record-btn {{selectedEmotion ? 'selected' : ''}}"
        bindtap="showEmotionPicker"
      >
        <view class="record-icon">{{selectedEmotion ? selectedEmotion.icon : '📝'}}</view>
        <view class="record-text">{{selectedEmotion ? selectedEmotion.label : '点击记录此刻心情'}}</view>
      </view>
      <!-- AI 日记按钮 -->
      <view class="diary-btn" bindtap="showEmotionPicker">
        <view class="diary-icon">🤖</view>
        <view class="diary-text">AI智能日记</view>
      </view>
    </view>
  </view>

  <!-- 今日记录统计 -->
  <view class="today-stats">
    <text class="stats-text">今日已记录 {{todayCount}} 次</text>
  </view>

  <!-- 今日记录列表 -->
  <view class="records-list" wx:if="{{todayRecords.length > 0}}">
    <view class="section-title">今日记录</view>
    <view wx:for="{{todayRecords}}" wx:key="_id" class="record-item">
      <view class="record-main">
        <view class="record-left">
          <view class="record-period">{{item.period_icon}} {{item.period_label}}</view>
          <view class="record-time">{{item.formatted_time}}</view>
        </view>
        <view class="record-emotion">{{item.emotion_icon}} {{item.emotion_label}}</view>
      </view>
      <view class="record-text-content" wx:if="{{item.text}}">{{item.text}}</view>
      <!-- AI 陪伴回应 -->
      <view class="record-ai-response" wx:if="{{item.ai_response}}">
        <view class="ai-tag">🤖 AI</view>
        <view class="ai-text">{{item.ai_response}}</view>
      </view>
    </view>
  </view>

  <!-- 连续打卡 -->
  <view class="streak-section" wx:if="{{userStats.streak > 0}}">
    <view class="streak-card">
      <view class="streak-icon">🔥</view>
      <view class="streak-info">
        <view class="streak-count">连续打卡 {{userStats.streak}} 天</view>
        <view class="streak-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{streakProgress}}%"></view>
          </view>
          <view class="progress-text">{{userStats.max_streak}}天最高记录</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-tips" wx:if="{{todayRecords.length === 0}}">
    <view class="empty-icon">💭</view>
    <view class="empty-text">还没有记录哦</view>
    <view class="empty-subtext">点击上方按钮，记录今天的第一条情绪</view>
    <view class="empty-subtext">或试试 AI 智能日记，写什么都能记录 ✨</view>
  </view>
</view>

<!-- 情绪选择弹窗 -->
<view class="emotion-modal {{showModal ? 'show' : ''}}" bindtap="hideEmotionPicker">
  <view class="modal-content" catchtap="stopPropagation">
    <!-- 模式切换 -->
    <view class="mode-tabs">
      <view class="mode-tab {{!diaryMode ? 'active' : ''}}" bindtap="switchToManual">手动选择</view>
      <view class="mode-tab {{diaryMode ? 'active' : ''}}" bindtap="switchToDiary">🤖 AI日记</view>
    </view>

    <!-- 手动选择模式 -->
    <view wx:if="{{!diaryMode}}">
      <view class="modal-title">现在感觉怎么样？</view>
      <view class="emotion-grid">
        <view 
          wx:for="{{emotions}}" 
          wx:key="key"
          class="emotion-option {{tempEmotion.key === item.key ? 'selected' : ''}}"
          bindtap="selectEmotion"
          data-emotion="{{item}}"
        >
          <block wx:if="{{item.iconType === 'image'}}">
            <image class="emotion-img" src="{{item.icon}}" mode="aspectFit"></image>
          </block>
          <block wx:else>
            <view class="emotion-icon">{{item.icon}}</view>
          </block>
          <view class="emotion-label">{{item.label}}</view>
        </view>
      </view>
      <view class="text-input-section">
        <view class="text-label">添加文字（可选）</view>
        <textarea 
          class="text-input" 
          placeholder="记录此刻的心情..." 
          maxlength="200"
          bindinput="onTextInput"
          value="{{tempText}}"
        ></textarea>
        <view class="text-count">{{tempText.length}}/200</view>
      </view>
      <view class="modal-actions">
        <view class="btn-cancel" bindtap="hideEmotionPicker">取消</view>
        <view class="btn-confirm {{aiLoading ? 'loading' : ''}}" bindtap="confirmRecord">
          {{aiLoading ? '🤖 AI思考中...' : '确定保存'}}
        </view>
      </view>
    </view>

    <!-- AI 日记模式 -->
    <view wx:else>
      <view class="modal-title">写点什么吧 ✍️</view>
      <view class="diary-desc">打字或按住麦克风语音输入，AI 自动理解你的情绪</view>
      <view class="text-input-section">
        <textarea 
          class="text-input diary-textarea" 
          placeholder="今天发生了什么？心情怎么样？想到什么都可以写..." 
          maxlength="500"
          bindinput="onDiaryInput"
          value="{{diaryText}}"
        ></textarea>
        <!-- 语音按钮 -->
        <view class="voice-row">
          <view class="text-count">{{diaryText.length}}/500</view>
          <view 
            class="voice-btn {{isRecording ? 'recording' : ''}}" 
            bindtouchstart="startVoiceInput" 
            bindtouchend="stopVoiceInput"
            bindtouchcancel="cancelVoiceInput"
          >
            <text class="voice-icon">{{isRecording ? '⏺' : '🎙️'}}</text>
            <text class="voice-label">{{isRecording ? '松开结束' : '按住说话'}}</text>
          </view>
        </view>
        <!-- 录音状态提示 -->
        <view class="recording-tip" wx:if="{{isRecording}}">
          <view class="recording-anim">
            <view class="recording-wave"></view>
            <view class="recording-wave"></view>
            <view class="recording-wave"></view>
          </view>
          <text>{{recordingText}}</text>
        </view>
      </view>
      <view class="modal-actions">
        <view class="btn-cancel" bindtap="hideEmotionPicker">取消</view>
        <view class="btn-confirm {{aiLoading ? 'loading' : ''}}" bindtap="confirmDiary">
          {{aiLoading ? '🤖 AI理解中...' : '🤖 让AI来理解'}}
        </view>
      </view>
    </view>
  </view>
</view>

<!-- Toast -->
<view class="toast" wx:if="{{showToast}}">
  <view class="toast-icon">✓</view>
  <view class="toast-text">{{toastText}}</view>
</view>
