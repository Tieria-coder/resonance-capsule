/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #ffffff 100%);
  padding-bottom: 120rpx;
}

.header {
  padding: 30rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* AI 回应气泡 */
.ai-bubble {
  position: fixed;
  top: 100rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 200;
  opacity: 0;
  transform: translateY(-20rpx);
  transition: all 0.3s ease;
  pointer-events: none;
}

.ai-bubble.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.ai-bubble-content {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.ai-bubble-icon {
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.ai-bubble-text {
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.ai-bubble-hint {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 记录按钮区域 */
.record-section {
  padding: 40rpx 30rpx 20rpx;
  display: flex;
  justify-content: center;
}

.record-btn-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.record-btn {
  width: 360rpx;
  height: 360rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

.record-btn:active {
  transform: scale(0.95);
}

.record-btn.selected {
  background: linear-gradient(135deg, #81C784 0%, #4CAF50 100%);
}

.record-icon {
  font-size: 90rpx;
  margin-bottom: 16rpx;
}

.record-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* AI 日记按钮 */
.diary-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.3);
}

.diary-btn:active {
  opacity: 0.9;
  transform: scale(0.97);
}

.diary-icon {
  font-size: 36rpx;
}

.diary-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* 今日统计 */
.today-stats {
  text-align: center;
  padding: 10rpx 20rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #666;
}

/* 记录列表 */
.records-list {
  padding: 0 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.record-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.record-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-period {
  font-size: 24rpx;
  color: #999;
}

.record-time {
  font-size: 24rpx;
  color: #bbb;
}

.record-emotion {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.record-text-content {
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* AI 陪伴回应 */
.record-ai-response {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}

.ai-tag {
  font-size: 22rpx;
  color: #667eea;
  white-space: nowrap;
}

.ai-text {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  flex: 1;
}

/* 连续打卡 */
.streak-section {
  padding: 30rpx;
}

.streak-card {
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 152, 0, 0.3);
}

.streak-icon { font-size: 60rpx; }

.streak-info { flex: 1; }

.streak-count {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.streak-progress {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 空状态 */
.empty-tips {
  padding: 60rpx 30rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 弹窗 */
.emotion-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.emotion-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx 30rpx 60rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  overflow-y: auto;
}

.emotion-modal.show .modal-content {
  transform: translateY(0);
}

/* 模式切换 Tab */
.mode-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 30rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.mode-tab.active {
  background: #fff;
  color: #333;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.modal-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.diary-desc {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

/* 情绪选择网格 */
.emotion-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.emotion-option {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.emotion-option .emotion-icon { font-size: 50rpx; }
.emotion-img { width: 50rpx; height: 50rpx; border-radius: 8rpx; }
.emotion-option .emotion-label { font-size: 22rpx; color: #666; margin-top: 8rpx; }

.emotion-option.selected {
  background: #E8F5E9;
  transform: scale(1.05);
}

.emotion-option.selected .emotion-label {
  color: #4CAF50;
  font-weight: 500;
}

/* 文字输入 */
.text-input-section {
  margin-bottom: 24rpx;
}

.text-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.text-input {
  width: 100%;
  height: 140rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.diary-textarea {
  height: 200rpx;
}

/* 语音按钮行 */
.voice-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.voice-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f0f0ff;
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  transition: all 0.2s;
}

.voice-btn.recording {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);
  animation: pulse 1.2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.voice-icon {
  font-size: 32rpx;
}

.voice-label {
  font-size: 24rpx;
  color: #666;
}

.voice-btn.recording .voice-label {
  color: #fff;
}

/* 录音状态提示 */
.recording-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f8f7ff;
  border-radius: 12rpx;
  color: #667eea;
  font-size: 24rpx;
}

.recording-anim {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.recording-wave {
  width: 6rpx;
  height: 24rpx;
  background: #667eea;
  border-radius: 3rpx;
  animation: wave 0.8s infinite ease-in-out;
}

.recording-wave:nth-child(2) { animation-delay: 0.1s; height: 32rpx; }
.recording-wave:nth-child(3) { animation-delay: 0.2s; height: 20rpx; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1.2); }
}

.text-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.3);
}

.btn-confirm:active { opacity: 0.9; }

.btn-confirm.loading {
  opacity: 0.7;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.8);
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 9999;
}

.toast-icon { color: #4CAF50; font-size: 32rpx; }
.toast-text { color: #fff; font-size: 28rpx; }
