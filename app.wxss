/* app.wxss - 黑白质感风格（小程序兼容） */

page {
  background: linear-gradient(180deg, #f8f8f8 0%, #eeeeee 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'Segoe UI', Arial, Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a1a;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #fafafc;
}

/* ═══ 通用按钮 ═══ */
.btn-primary {
  background: rgba(26,26,26,0.85);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  border: 1.5rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  transition: all 0.2s;
}

.btn-primary:active {
  transform: scale(0.95);
  background: rgba(26,26,26,0.95);
}

/* ═══ 卡片样式 ═══ */
.card {
  background: rgba(255,255,255,0.75);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07), 0 1rpx 4rpx rgba(0,0,0,0.04);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

/* ═══ 情绪列表 ═══ */
.emotion-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
}

.emotion-item {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.75);
  transition: all 0.2s ease;
  border: 1.5rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.emotion-item.selected {
  transform: scale(1.1);
  background: rgba(255,255,255,0.9);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border-color: rgba(26,26,26,0.15);
}

.emotion-icon {
  font-size: 50rpx;
  line-height: 1;
}

.emotion-label {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
}

/* ═══ Toast 提示 ═══ */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(26,26,26,0.85);
  color: #ffffff;
  padding: 20rpx 40rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
  border: 1.5rpx solid rgba(255,255,255,0.5);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ═══ 空状态 ═══ */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}

/* ═══ 加载中 ═══ */
.loading {
  text-align: center;
  padding: 50rpx;
  color: #999;
  font-size: 28rpx;
}

/* ═══ 分隔线 ═══ */
.divider {
  height: 1rpx;
  background: rgba(0,0,0,0.06);
  margin: 30rpx 0;
}

/* ═══ 徽章样式 ═══ */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.75);
  color: #666;
  border: 1.5rpx solid rgba(0,0,0,0.04);
}

.badge-active {
  background: rgba(255,255,255,0.9);
  color: #1a1a1a;
  font-weight: 500;
  border-color: rgba(26,26,26,0.15);
}

/* ═══ 导航占位 ═══ */
.nav-placeholder {
  height: 120rpx;
}

/* ═══ 图标动画（仅保留功能性动画） ═══ */

@keyframes pop-bounce {
  0% { transform: scale(1); }
  30% { transform: scale(1.18); }
  60% { transform: scale(0.95); }
  80% { transform: scale(1.06); }
  100% { transform: scale(1); }
}

@keyframes mic-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.15; }
}

/* 通用图标尺寸 */
.icon-xs { width: 32rpx; height: 32rpx; }
.icon-sm { width: 40rpx; height: 40rpx; }
.icon-md { width: 48rpx; height: 48rpx; }
.icon-lg { width: 64rpx; height: 64rpx; }
.icon-xl { width: 80rpx; height: 80rpx; }

/* 功能性动画 class */
.icon-anim-mic { animation: mic-pulse 1.5s ease-in-out infinite; }
.icon-anim-pop { animation: pop-bounce 0.6s ease-out forwards; }
.icon-anim-success { animation: pop-bounce 0.5s ease-out forwards; }
